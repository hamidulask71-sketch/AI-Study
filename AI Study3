package com.shikkhashathi;

import android.os.Bundle;
import android.view.View;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;
import java.util.ArrayList;
import java.util.Random;

public class MainActivity extends AppCompatActivity {

    // ভেরিয়েবল ডিক্লেয়ারেশন
    private Button btnBangla, btnEnglish;
    private Button tabChat, tabMath, tabDaily;
    private LinearLayout chatTab, mathTab, dailyTab;
    private EditText messageInput, mathInput;
    private Button sendBtn, solveMathBtn, showAnswerBtn, newDailyBtn;
    private TextView mathSolution, dailyQuestion, dailyAnswer;
    private LinearLayout mathResultLayout, answerLayout;
    private RecyclerView chatRecyclerView;
    
    private ArrayList<String> messageList;
    private ArrayAdapter<String> chatAdapter;
    private String currentLang = "bn";
    private Random random;
    
    // ডেইলি প্রবলেম ডাটাবেজ
    private String[][] dailyProblems = {
        {"একটি আয়তক্ষেত্রের দৈর্ঘ্য ১০ মিটার এবং প্রস্থ ৫ মিটার। এর ক্ষেত্রফল কত?", 
         "আয়তক্ষেত্রের ক্ষেত্রফল = দৈর্ঘ্য × প্রস্থ = ১০ × ৫ = ৫০ বর্গমিটার।"},
        {"একটি বৃত্তের ব্যাসার্ধ ৭ সেমি। এর পরিধি কত? (π = ৩.১৪)", 
         "বৃত্তের পরিধি = ২πr = ২ × ৩.১৪ × ৭ = ৪৩.৯৬ সেমি।"},
        {"১০ টি আমের দাম ২০০ টাকা। ৫টি আমের দাম কত?", 
         "১টি আমের দাম = ২০০ ÷ ১০ = ২০ টাকা, ৫টি আমের দাম = ২০ × ৫ = ১০০ টাকা।"},
        {"একটি সংখ্যার ২০% হলো ৪০। সংখ্যাটি কত?", 
         "সংখ্যা × (২০/১০০) = ৪০ → সংখ্যা = ৪০ × (১০০/২০) = ২০০।"},
        {"যদি a = ৫ এবং b = ৩ হয়, তাহলে a² + b² = কত?", 
         "a² + b² = ৫² + ৩² = ২৫ + ৯ = ৩৪।"}
    };
    
    private int currentDailyIndex = 0;
    
    // ইংলিশ ভার্সন
    private String[][] dailyProblemsEn = {
        {"A rectangle has length 10m and width 5m. What is its area?", 
         "Area of rectangle = length × width = 10 × 5 = 50 square meters."},
        {"A circle has radius 7cm. What is its circumference? (π = 3.14)", 
         "Circumference = 2πr = 2 × 3.14 × 7 = 43.96 cm."},
        {"10 mangoes cost 200 taka. What is the cost of 5 mangoes?", 
         "Price of 1 mango = 200 ÷ 10 = 20 taka, Price of 5 mangoes = 20 × 5 = 100 taka."},
        {"20% of a number is 40. Find the number.", 
         "Number × (20/100) = 40 → Number = 40 × (100/20) = 200."},
        {"If a = 5 and b = 3, then a² + b² = ?", 
         "a² + b² = 5² + 3² = 25 + 9 = 34."}
    };

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);
        
        random = new Random();
        
        // ভিউ আইডি সংযোগ
        initViews();
        
        // চ্যাট সেটআপ
        setupChat();
        
        // ক্লিক লিসেনার সেটআপ
        setupClickListeners();
        
        // ডিফল্ট ট্যাব
        selectTab(0);
        
        // ওয়েলকাম মেসেজ
        addWelcomeMessage();
    }
    
    private void initViews() {
        btnBangla = findViewById(R.id.btnBangla);
        btnEnglish = findViewById(R.id.btnEnglish);
        tabChat = findViewById(R.id.tabChat);
        tabMath = findViewById(R.id.tabMath);
        tabDaily = findViewById(R.id.tabDaily);
        chatTab = findViewById(R.id.chatTab);
        mathTab = findViewById(R.id.mathTab);
        dailyTab = findViewById(R.id.dailyTab);
        messageInput = findViewById(R.id.messageInput);
        mathInput = findViewById(R.id.mathInput);
        sendBtn = findViewById(R.id.sendBtn);
        solveMathBtn = findViewById(R.id.solveMathBtn);
        showAnswerBtn = findViewById(R.id.showAnswerBtn);
        newDailyBtn = findViewById(R.id.newDailyBtn);
        mathSolution = findViewById(R.id.mathSolution);
        dailyQuestion = findViewById(R.id.dailyQuestion);
        dailyAnswer = findViewById(R.id.dailyAnswer);
        mathResultLayout = findViewById(R.id.mathResultLayout);
        answerLayout = findViewById(R.id.answerLayout);
        chatRecyclerView = findViewById(R.id.chatRecyclerView);
    }
    
    private void setupChat() {
        messageList = new ArrayList<>();
        chatAdapter = new ArrayAdapter<>(this, android.R.layout.simple_list_item_1, messageList);
        chatRecyclerView.setLayoutManager(new LinearLayoutManager(this));
        chatRecyclerView.setAdapter(chatAdapter);
    }
    
    private void addWelcomeMessage() {
        String welcome = currentLang.equals("bn") ? 
            "👋 হ্যালো! আমি আপনার এআই শিক্ষা সহায়ক। যেকোনো প্রশ্ন করতে পারেন।" :
            "👋 Hello! I'm your AI Learning Assistant. Ask me any question!";
        messageList.add(welcome);
        chatAdapter.notifyDataSetChanged();
    }
    
    private void setupClickListeners() {
        // ভাষা বাটন
        btnBangla.setOnClickListener(v -> changeLanguage("bn"));
        btnEnglish.setOnClickListener(v -> changeLanguage("en"));
        
        // ট্যাব বাটন
        tabChat.setOnClickListener(v -> selectTab(0));
        tabMath.setOnClickListener(v -> selectTab(1));
        tabDaily.setOnClickListener(v -> selectTab(2));
        
        // সেন্ড বাটন
        sendBtn.setOnClickListener(v -> sendMessage());
        
        // গণিত সলভ বাটন
        solveMathBtn.setOnClickListener(v -> solveMathProblem());
        
        // ডেইলি প্রবলেম বাটন
        showAnswerBtn.setOnClickListener(v -> showDailyAnswer());
        newDailyBtn.setOnClickListener(v -> loadNewDailyProblem());
    }
    
    private void changeLanguage(String lang) {
        currentLang = lang;
        
        // বাটন স্টাইল পরিবর্তন
        if (lang.equals("bn")) {
            btnBangla.setBackgroundResource(R.drawable.lang_btn_active);
            btnEnglish.setBackgroundResource(R.drawable.lang_btn_inactive);
            btnBangla.setTextColor(getColor(R.color.primary_color));
            btnEnglish.setTextColor(getColor(R.color.white));
        } else {
            btnBangla.setBackgroundResource(R.drawable.lang_btn_inactive);
            btnEnglish.setBackgroundResource(R.drawable.lang_btn_active);
            btnBangla.setTextColor(getColor(R.color.white));
            btnEnglish.setTextColor(getColor(R.color.primary_color));
        }
        
        // চ্যাট ক্লিয়ার করে নতুন ওয়েলকাম মেসেজ
        messageList.clear();
        addWelcomeMessage();
        
        // ম্যাথ প্লেসহোল্ডার পরিবর্তন
        if (lang.equals("bn")) {
            mathInput.setHint("যেমন: (25 + 15) × 2 = ?");
        } else {
            mathInput.setHint("Example: (25 + 15) × 2 = ?");
        }
        
        // ডেইলি প্রবলেম রিফ্রেশ
        loadNewDailyProblem();
    }
    
    private void selectTab(int tabIndex) {
        // সব ট্যাব লুকান
        chatTab.setVisibility(View.GONE);
        mathTab.setVisibility(View.GONE);
        dailyTab.setVisibility(View.GONE);
        
        // বাটন স্টাইল রিসেট
        tabChat.setBackgroundResource(R.drawable.tab_inactive);
        tabMath.setBackgroundResource(R.drawable.tab_inactive);
        tabDaily.setBackgroundResource(R.drawable.tab_inactive);
        tabChat.setTextColor(getColor(R.color.gray));
        tabMath.setTextColor(getColor(R.color.gray));
        tabDaily.setTextColor(getColor(R.color.gray));
        
        // সিলেক্টেড ট্যাব দেখান
        if (tabIndex == 0) {
            chatTab.setVisibility(View.VISIBLE);
            tabChat.setBackgroundResource(R.drawable.tab_active);
            tabChat.setTextColor(getColor(R.color.primary_color));
        } else if (tabIndex == 1) {
            mathTab.setVisibility(View.VISIBLE);
            tabMath.setBackgroundResource(R.drawable.tab_active);
            tabMath.setTextColor(getColor(R.color.primary_color));
        } else {
            dailyTab.setVisibility(View.VISIBLE);
            tabDaily.setBackgroundResource(R.drawable.tab_active);
            tabDaily.setTextColor(getColor(R.color.primary_color));
        }
    }
    
    private void sendMessage() {
        String question = messageInput.getText().toString().trim();
        if (question.isEmpty()) return;
        
        // ইউজারের মেসেজ যোগ করুন
        messageList.add("👤 " + question);
        chatAdapter.notifyDataSetChanged();
        messageInput.setText("");
        
        // এআই উত্তর জেনারেট করুন
        String answer = getAIAnswer(question);
        messageList.add("🤖 " + answer);
        chatAdapter.notifyDataSetChanged();
        
        // স্ক্রল টু বটম
        chatRecyclerView.scrollToPosition(messageList.size() - 1);
    }
    
    private String getAIAnswer(String question) {
        String q = question.toLowerCase();
        
        // গণিতের সমস্যা চেক
        if (q.contains("+") || q.contains("-") || q.contains("×") || q.contains("*")) {
            try {
                String expr = question.replace("×", "*").replace("÷", "/").replaceAll("\\s", "");
                double result = evaluateExpression(expr);
                return currentLang.equals("bn") ? "উত্তর: " + result : "Answer: " + result;
            } catch (Exception e) {
                return currentLang.equals("bn") ? "গণিতের সমস্যাটি সঠিকভাবে লিখুন" : "Please write math problem correctly";
            }
        }
        
        // সাধারণ জ্ঞানের উত্তর
        if (q.contains("ঢাকা") || q.contains("dhaka")) {
            return currentLang.equals("bn") ? "ঢাকা বাংলাদেশের রাজধানী। এটি বুড়িগঙ্গা নদীর তীরে অবস্থিত।" : 
                   "Dhaka is the capital of Bangladesh. It is located on the Buriganga River.";
        }
        if (q.contains("বাংলাদেশ") || q.contains("bangladesh")) {
            return currentLang.equals("bn") ? "বাংলাদেশ দক্ষিণ এশিয়ার একটি দেশ। স্বাধীনতা লাভ করে ১৯৭১ সালে।" :
                   "Bangladesh is a country in South Asia. It gained independence in 1971.";
        }
        if (q.contains("সূর্য") || q.contains("sun")) {
            return currentLang.equals("bn") ? "সূর্য আমাদের সৌরজগতের কেন্দ্র। এটি একটি নক্ষত্র।" :
                   "The Sun is the center of our solar system. It is a star.";
        }
        if (q.contains("চাঁদ") || q.contains("moon")) {
            return currentLang.equals("bn") ? "চাঁদ পৃথিবীর একমাত্র প্রাকৃতিক উপগ্রহ।" :
                   "The Moon is Earth's only natural satellite.";
        }
        if (q.contains("পানি") || q.contains("water")) {
            return currentLang.equals("bn") ? "পানির রাসায়নিক সংকেত H₂O। এটি জীবন ধারণের জন্য অপরিহার্য।" :
                   "Water's chemical formula is H₂O. It is essential for life.";
        }
        
        // ডিফল্ট উত্তর
        return currentLang.equals("bn") ? 
            "এটি একটি ভালো প্রশ্ন। আরও জানতে চাইলে নির্দিষ্ট করে জিজ্ঞাসা করুন।" :
            "This is a good question. Please ask more specifically for detailed answers.";
    }
    
    private double evaluateExpression(String expr) {
        // সহজ গণিত ইভালুয়েশন
        if (expr.contains("+")) {
            String[] parts = expr.split("\\+");
            return Double.parseDouble(parts[0]) + Double.parseDouble(parts[1]);
        } else if (expr.contains("-")) {
            String[] parts = expr.split("-");
            return Double.parseDouble(parts[0]) - Double.parseDouble(parts[1]);
        } else if (expr.contains("*")) {
            String[] parts = expr.split("\\*");
            return Double.parseDouble(parts[0]) * Double.parseDouble(parts[1]);
        } else if (expr.contains("/")) {
            String[] parts = expr.split("/");
            return Double.parseDouble(parts[0]) / Double.parseDouble(parts[1]);
        }
        return Double.parseDouble(expr);
    }
    
    private void solveMathProblem() {
        String problem = mathInput.getText().toString().trim();
        if (problem.isEmpty()) {
            mathSolution.setText(currentLang.equals("bn") ? "দয়া করে একটি গণিত সমস্যা লিখুন" : "Please enter a math problem");
            mathResultLayout.setVisibility(View.VISIBLE);
            return;
        }
        
        try {
            String expr = problem.replace("×", "*").replace("÷", "/").replaceAll("\\s", "");
            double result = evaluateExpression(expr);
            String solution = currentLang.equals("bn") ? "সমাধান: " + result : "Solution: " + result;
            mathSolution.setText(solution);
            mathResultLayout.setVisibility(View.VISIBLE);
        } catch (Exception e) {
            mathSolution.setText(currentLang.equals("bn") ? 
                "গণিতের সমস্যাটি সঠিকভাবে লিখুন (যেমন: 25+15)" : 
                "Please write math problem correctly (ex: 25+15)");
            mathResultLayout.setVisibility(View.VISIBLE);
        }
    }
    
    private void showDailyAnswer() {
        String answer;
        if (currentLang.equals("bn")) {
            answer = dailyProblems[currentDailyIndex][1];
        } else {
            answer = dailyProblemsEn[currentDailyIndex][1];
        }
        dailyAnswer.setText(answer);
        answerLayout.setVisibility(View.VISIBLE);
    }
    
    private void loadNewDailyProblem() {
        currentDailyIndex = random.nextInt(dailyProblems.length);
        
        String question;
        if (currentLang.equals("bn")) {
            question = dailyProblems[currentDailyIndex][0];
        } else {
            question = dailyProblemsEn[currentDailyIndex][0];
        }
        
        dailyQuestion.setText(question);
        answerLayout.setVisibility(View.GONE);
        mathResultLayout.setVisibility(View.GONE);
    }
}
